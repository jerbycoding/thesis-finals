portrait = "👨‍💻"
lines = [
	{"choices": [], "text": "Did you see those logs this morning? It looks like the same signature as last Monday, but... evolved."},
	{"choices": [], "text": "I think we missed something. If you see any repeating IPs, prioritize them. We can't let them establish persistence."}
