[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "CISO"
portrait = "👔"
lines = [
    {"choices": [], "text": "The threat is no longer just external, analyst. We've detected anomalies that suggest one of our own may be compromising organizational integrity."},
    {"choices": [{"effect": {"change_scene": "res://scenes/SOC_Office.tscn", "then_start_narrative": "shift_thursday"}, "text": "I'll keep a close eye on internal traffic."}], "text": "Trust is a luxury we cannot afford today. Scrutinize every internal log. If an employee is exfiltrating data, they'll be using their standard credentials to hide in plain sight. Stay sharp."}
]
