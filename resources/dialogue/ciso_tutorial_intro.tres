[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "CISO"
portrait = "👔"
lines = [
    {"choices": [], "text": "Analyst, welcome to your first day. This is a non-live training simulation. We're going to walk through the basic SOC protocol."},
    {"choices": [], "text": "Before you touch a terminal, you need to familiarize yourself with the office layout. Head down the hallway to your assigned room: Office C."},
    {"choices": [{"effect": {"change_scene": "res://scenes/SOC_Office.tscn", "then_start_narrative": "shift_tutorial"}, "text": "Understood. Locating Office C."}], "text": "Locate your workstation and initialize the session. I'll provide your first case once you're seated. Move out."}
]