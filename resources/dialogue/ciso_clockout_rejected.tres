script = ExtResource("1_dialogue_data")
npc_name = "CISO"
portrait = "👔"
lines = [
    {"choices": [], "text": "Clock out early? Let me look at your station... Negative, analyst. My monitor shows active alerts or pending investigations in your queue."},
    {"choices": [], "text": "We don't leave until the job is done. Return to your terminal and clear those tickets. Security is a 24/7 commitment."}
]
