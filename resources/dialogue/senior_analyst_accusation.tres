[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
npc_name = "Senior Analyst"
portrait = "👨‍💻"
lines = [
	{"choices": [], "text": "I've been tracking the 'admin' logins. They match IT Support's shift pattern... but the IPs are all wrong."},
	{"choices": [
		{"text": "I'll investigate the logs myself.", "effect": {"npc": "senior_analyst", "relationship_change": 0.1}},
		{"text": "Are you saying IT is the mole?", "effect": {"npc": "senior_analyst", "relationship_change": 0.0}}
	], "text": "I'm not saying it's him... but someone with his credentials is tearing down our firewalls from the inside. Be careful who you trust today."},
	{"choices": [], "text": "Double check every 'maintenance' claim. If the IP is external, it's a lie."}
]
