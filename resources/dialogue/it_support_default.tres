lines = [
    {"choices": [{"effect": {"relationship_change": 0.0}, "text": "Just checking in."}, {"effect": {"relationship_change": -0.1}, "text": "Can you restore a disabled tool?"}, {"effect": {"relationship_change": 0.1}, "text": "Thanks for your work."}], "text": "Yeah? What do you need? I'm swamped with tickets. If you broke something, it'll take time to fix."}
]
