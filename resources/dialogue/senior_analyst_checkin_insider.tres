[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "Senior Analyst"
portrait = "👨‍💻"
lines = [
    {"choices": [{"effect": {"npc": "senior_analyst", "relationship_change": 0.2}, "text": "I'll follow the evidence."}, {"effect": {"npc": "senior_analyst", "relationship_change": -0.2}, "text": "Maybe it's one of us?"}, {"effect": {"npc": "senior_analyst", "relationship_change": 0.0}, "text": "I'm just doing my job."}], "text": "We've got a mole. I can feel it. But remember: in the SOC, evidence is the only thing that matters. Don't let paranoia blind you to the logs."},
    {"choices": [], "text": "Accusing someone without forensic proof is how you get fired. Stick to the data."}
]
