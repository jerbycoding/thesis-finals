[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "IT Support"
portrait = "🔧"
lines = [
    {"choices": [], "text": "Look, I'm busy. What do you want? If it's about the terminal speed, I'm already looking at the router logs."},
    {"choices": [
        {"text": "I need a bandwidth priority boost.", "effect": {"favor": {"id": "boost_bandwidth", "cost": 0.3}}},
        {"text": "Just checking in.", "effect": {}}
    ], "text": "I can prioritize your station's traffic, but it's going to make my life harder later. You really need it?"},
    {"choices": [], "text": "Fine. I'll open up the pipes for a minute. Don't make me regret it."}
]
