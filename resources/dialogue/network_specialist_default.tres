[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "Network Specialist"
portrait = "🌐"
lines = [
    {"choices": [], "text": "The backbone is taking a beating today. I'm seeing strange routing tables and dropped packets across the entire internal subnet."},
    {"choices": [
        {"text": "Is the network map accurate?", "effect": {}},
        {"text": "Any signs of external scanning?", "effect": {"npc": "network_specialist", "relationship_change": 0.1}}
    ], "text": "Are you here to help me verify the topology, or just checking the logs?"},
    {"choices": [], "text": "Keep an eye on the Terminal for any 'Packet Loss' warnings. If you see them, it means the firewall is being overwhelmed. Stay vigilant."}
]
