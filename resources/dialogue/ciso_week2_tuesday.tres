[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
npc_name = "CISO"
portrait = "👔"
lines = [
	{"choices": [], "text": "Report, analyst. The network is behaving erratically. We're seeing 'Ghost Logs'—events appearing in the SIEM that don't match our firewall telemetry."},
	{"choices": [{"effect": {"change_scene": "res://scenes/SOC_Office.tscn", "then_start_narrative": "shift_week2_tuesday"}, "text": "I'll investigate the discrepancy."}], "text": "It feels like someone is trying to rewrite the history of our own network. Watch for supply chain alerts. If our vendors are compromised, we are compromised. Go."}
]
