[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
npc_name = "CISO"
portrait = "👔"
lines = [
	{"choices": [], "text": "The leak is coming from the inside, analyst. We have credentialed users performing unauthorized reboots and scrubbing logs. Trust is a luxury we can't afford."},
	{"choices": [{"effect": {"change_scene": "res://scenes/SOC_Office.tscn", "then_start_narrative": "shift_week2_thursday"}, "text": "I'll watch my colleagues as closely as the attackers."}], "text": "I need you to hunt the mole. Scrutinize IT Support, the Senior Analyst, everyone. If a command originates from an internal IP, don't assume it's authorized. Follow the truth, not the user ID."}
]
