[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue_data"]

[resource]
script = ExtResource("1_dialogue_data")
npc_name = "CISO"
portrait = "👔"
lines = [
    {"choices": [], "text": "The signal is still unstable, analyst. I need those nodes calibrated before the maintenance window closes. If we miss this window, the integrity of the entire subnet is at risk."},
    {"choices": [
        {"text": "Which node is the priority right now?", "effect": {}},
        {"text": "I'm working as fast as I can.", "effect": {}}
    ], "text": "Report status. What is your current objective?"},
    {"choices": [], "text": "My monitor shows that node [color=cyan]{next_node}[/color] is still reporting signal loss. Get to it immediately."}
]
