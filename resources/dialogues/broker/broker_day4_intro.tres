[resource]
script = ExtResource("1_dialogue")
npc_name = "Broker"
portrait = "🕴️"
is_randomized = false
lines = Array[Dictionary]([{
"text": "The corporate core is hardening. Their AI analyst has flagged our recent activity."
}, {
"text": "Subtlety is no longer an option. We need to extract their communications archive directly."
}, {
"text": "Expect them to watch the network closely. If you stay on a host too long, they will isolate you."
}])
