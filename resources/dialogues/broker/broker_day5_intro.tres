[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" uid="uid://c2lpqyroyo4be" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
npc_name = "Broker"
portrait = "🕴️"
is_randomized = false
lines = Array[Dictionary]([{
"text": "The digital shadow we've left is too large. Their SIEM is glowing red with our telemetry."
}, {
"text": "Your objective is simple: delete the evidence. Use the Wiper payload on the primary database server."
}, {
"text": "Destroy the logs, and our trace level will drop. Fail, and we're blind."
}])
