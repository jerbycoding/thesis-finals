[gd_resource type="Resource" script_class="DialogueDataResource" load_steps=2 format=3]

[ext_resource type="Script" uid="uid://c2lpqyroyo4be" path="res://resources/dialogue/DialogueDataResource.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
npc_name = "Broker"
portrait = "🕴️"
is_randomized = false
lines = Array[Dictionary]([{
"text": "Day Three. You're still connected. That's more than I can say for most."
}, {
"text": "I've reviewed your activity logs. You're competent. Reckless, but competent."
}, {
"text": "One more contract today. Same as before."
}, {
"text": "But after this... there's more to this operation than I've told you."
}, {
"text": "When you're done, we'll talk. Properly. Not through encrypted channels."
}, {
"text": "Complete the contract, then signal me. Don't keep me waiting."
}])
