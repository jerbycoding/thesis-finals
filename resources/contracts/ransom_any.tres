[ext_resource type="Script" path="res://scripts/resources/ContractResource.gd" id="1_contract"]

[resource]
script = ExtResource("1_contract")
ticket_id = "ransom_any"
title = "Ransom Any Host"
description = "Deploy ransomware on any accessible host. The target doesn't matter — just spread the infection."
