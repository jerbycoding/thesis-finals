[resource]
script = ExtResource("1_contract")
ticket_id = "wipe_siem"
title = "Digital Ghost"
description = "They're onto us. Clean up your footprints on {VAR:DB-SRV-01:name}. Use the Wiper script to overwrite their offensive logs."
