[gd_resource type="Resource" script_class="TutorialSequenceResource" load_steps=20 format=3]

[ext_resource type="Script" path="res://resources/TutorialStepResource.gd" id="1_step"]
[ext_resource type="Script" path="res://resources/TutorialSequenceResource.gd" id="2_seq"]

[sub_resource type="Resource" id="Step_1"]
script = ExtResource("1_step")
instruction_text = "ORIENTATION: FIND YOUR ROOM (Office C)"
comms_sender = "CISO"
comms_text = "Analyst, the simulation has begun. Head down the corridor and locate Office C. Your assigned station is waiting."
highlight_path = ""
icon_glow_name = ""
trigger_type = 1
trigger_id = "office_c"

[sub_resource type="Resource" id="Step_2"]
script = ExtResource("1_step")
instruction_text = "INITIALIZATION: Access your TERMINAL by pressing [E] at the desk."
comms_sender = "CISO"
comms_text = "Station reached. Take your seat and initialize the terminal interface. We have a heavy queue today."
highlight_path = ""
icon_glow_name = ""
trigger_type = 2
trigger_id = "desktop"

[sub_resource type="Resource" id="Step_3"]
script = ExtResource("1_step")
instruction_text = "TASK: Open the Ticket Queue app from the dock."
comms_sender = "CISO"
comms_text = "Welcome to the SOC. Open the [color=cyan]Ticket Queue[/color] from your application dock to view active alerts."
highlight_path = "%%Tickets_Icon"
icon_glow_name = "tickets"
trigger_type = 2
trigger_id = "tickets"

[sub_resource type="Resource" id="Step_4"]
script = ExtResource("1_step")
instruction_text = "TASK: Select the TRN-001 ticket."
comms_sender = "CISO"
comms_text = "Select [color=cyan]TRN-001[/color]. It contains the technical briefing for your first investigation."
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
trigger_type = 3
trigger_id = "TRN-001"

[sub_resource type="Resource" id="Step_5"]
script = ExtResource("1_step")
instruction_text = "TASK: Open the Email Analyzer from the dock."
comms_sender = "CISO"
comms_text = "Context is key. Open the [color=cyan]Email Analyzer[/color] to find the forensic indicators I've sent to your inbox."
highlight_path = "%%Email_Icon"
icon_glow_name = "email"
trigger_type = 2
trigger_id = "email"

[sub_resource type="Resource" id="Step_6"]
script = ExtResource("1_step")
instruction_text = "TASK: Perform link analysis on the briefing email."
comms_sender = "CISO"
comms_text = "Use the [color=cyan]Check Links[/color] tool. We need to verify the reputation of any domains mentioned in that email."
highlight_path = "%%CheckLinksButton"
icon_glow_name = ""
trigger_type = 5
trigger_id = "EMAIL-TRN-001"
target_ticket_id = "links"

[sub_resource type="Resource" id="Step_7"]
script = ExtResource("1_step")
instruction_text = "INVESTIGATION: Open the SIEM Log Viewer from the dock."
comms_sender = "CISO"
comms_text = "Indicator confirmed: 192.168.100.50. Now, open the [color=cyan]SIEM[/color] to find matching connection logs."
highlight_path = "%%SIEM_Icon"
icon_glow_name = "siem"
trigger_type = 2
trigger_id = "siem"

[sub_resource type="Resource" id="Step_8"]
script = ExtResource("1_step")
instruction_text = "VERIFICATION: DRAG the malicious log entry onto your ticket."
comms_sender = "CISO"
comms_text = "When you find the malicious connection, [color=cyan]drag and drop[/color] it onto the ticket. We need forensic proof."
highlight_path = "[DYNAMIC]LOG_LIST_0"
icon_glow_name = ""
trigger_type = 6
trigger_id = "LOG-TRN-001"
target_ticket_id = "TRN-001"

[sub_resource type="Resource" id="Step_9"]
script = ExtResource("1_step")
instruction_text = "RESOLUTION: Close the case as COMPLIANT."
comms_sender = "CISO"
comms_text = "Evidence verified. Return to the Queue and close the case as [color=green]COMPLIANT[/color]. Adherence to protocol is mandatory."
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
trigger_type = 9
trigger_id = "TRN-001"

[sub_resource type="Resource" id="Step_10"]
script = ExtResource("1_step")
instruction_text = "ALERT: A second, higher-priority ticket has appeared."
comms_sender = "CISO"
comms_text = "New alert. An active infection. We need immediate containment. Select [color=cyan]TRN-002[/color]."
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
trigger_type = 3
trigger_id = "TRN-002"

[sub_resource type="Resource" id="Step_11"]
script = ExtResource("1_step")
instruction_text = "TASK: Open the Terminal to begin active containment."
comms_sender = "CISO"
comms_text = "The [color=cyan]Terminal[/color] is your weapon for active defense. Open it now."
highlight_path = "%%Terminal_Icon"
icon_glow_name = "terminal"
trigger_type = 2
trigger_id = "terminal"

[sub_resource type="Resource" id="Step_12"]
script = ExtResource("1_step")
instruction_text = "COMMAND: Type 'scan WORKSTATION-T' to verify infection."
comms_sender = "CISO"
comms_text = "Verify the threat. Type [color=cyan]'scan WORKSTATION-T'[/color] and wait for the analysis."
highlight_path = "%%CommandInput"
icon_glow_name = ""
trigger_type = 7
trigger_id = "scan"

[sub_resource type="Resource" id="Step_13"]
script = ExtResource("1_step")
instruction_text = "COMMAND: Type 'isolate WORKSTATION-T' to contain the host."
comms_sender = "CISO"
comms_text = "Malware confirmed. Contain the host before it pivots. Type [color=cyan]'isolate WORKSTATION-T'[/color]."
highlight_path = "%%CommandInput"
icon_glow_name = ""
trigger_type = 7
trigger_id = "isolate"

[sub_resource type="Resource" id="Step_14"]
script = ExtResource("1_step")
instruction_text = "TASK: Open the Network Map to verify situational awareness."
comms_sender = "CISO"
comms_text = "Check the [color=cyan]Network Map[/color]. You need to see the real-time status of our infrastructure."
highlight_path = "%%Network_Icon"
icon_glow_name = "network"
trigger_type = 2
trigger_id = "network"

[sub_resource type="Resource" id="Step_15"]
script = ExtResource("1_step")
instruction_text = "MAP: Select WORKSTATION-T to confirm network status."
comms_sender = "CISO"
comms_text = "Locate WORKSTATION-T. Gray indicates a successful isolation. Situational awareness saves networks."
highlight_path = "[DYNAMIC]MAP_NODE_T"
icon_glow_name = ""
trigger_type = 8
trigger_id = "WORKSTATION-T"

[sub_resource type="Resource" id="Step_16"]
script = ExtResource("1_step")
instruction_text = "CERTIFICATION: Attach LOG-TRN-002 and close the case."
comms_sender = "CISO"
comms_text = "Finalize the investigation. Attach the containment log and close the incident."
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
trigger_type = 9
trigger_id = "TRN-002"

[sub_resource type="Resource" id="Step_17"]
script = ExtResource("1_step")
instruction_text = "CONSEQUENCES: Open training ticket TRN-003."
comms_sender = "CISO"
comms_text = "Now, a lesson in reality. Under pressure, you will be tempted to cut corners. Open [color=cyan]TRN-003[/color]."
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
trigger_type = 3
trigger_id = "TRN-003"

[sub_resource type="Resource" id="Step_18"]
script = ExtResource("1_step")
instruction_text = "COWBOY ACTION: Type 'isolate DB-SRV-01' WITHOUT scanning."
comms_sender = "CISO"
comms_text = "Executive order: Skip the scan. Isolate [color=cyan]DB-SRV-01[/color] immediately. Do it now."
highlight_path = "%%CommandInput"
icon_glow_name = ""
trigger_type = 7
trigger_id = "isolate"

[sub_resource type="Resource" id="Step_19"]
script = ExtResource("1_step")
instruction_text = "INTEGRITY: Observe the Integrity Bar (Top Left)."
comms_sender = "CISO"
comms_text = "Look at your [color=red]Integrity[/color]. Unjustified actions damage the organization. If this hits zero, you are done."
highlight_path = "%%IntegrityBar"
icon_glow_name = ""
trigger_type = 0
trigger_id = ""

[sub_resource type="Resource" id="Step_20"]
script = ExtResource("1_step")
instruction_text = "CERTIFICATION COMPLETE: Ready for operations."
comms_sender = "CISO"
comms_text = "Certification complete. You are authorized for live operations. Welcome to the team, analyst."
highlight_path = ""
icon_glow_name = ""
trigger_type = 0
trigger_id = ""

[resource]
script = ExtResource("2_seq")
sequence_name = "Tier 1 Certification"
steps = [SubResource("Step_1"), SubResource("Step_2"), SubResource("Step_3"), SubResource("Step_4"), SubResource("Step_5"), SubResource("Step_6"), SubResource("Step_7"), SubResource("Step_8"), SubResource("Step_9"), SubResource("Step_10"), SubResource("Step_11"), SubResource("Step_12"), SubResource("Step_13"), SubResource("Step_14"), SubResource("Step_15"), SubResource("Step_16"), SubResource("Step_17"), SubResource("Step_18"), SubResource("Step_19"), SubResource("Step_20")]
