[ext_resource type="Script" uid="uid://rynfgwjus7" path="res://resources/TutorialStepResource.gd" id="1_step"]
[ext_resource type="Script" uid="uid://ccj0ykd5pe1rw" path="res://resources/TutorialSequenceResource.gd" id="2_seq"]

[sub_resource type="Resource" id="Step_1"]
script = ExtResource("1_step")
instruction_text = "LOCATE OFFICE C"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Welcome aboard. Your physical location is part of the 'Insider Threat' security model. Head down the hall and find Office C—that's your assigned workstation."
highlight_tier = 3
highlight_path = ""
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 1
trigger_id = "office_c"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_2"]
script = ExtResource("1_step")
instruction_text = "LOG IN TO WORKSTATION"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Take a seat. Security starts with 'Identity and Access Management.' Use the credentials on the sticky note to log in to your secure environment."
highlight_tier = 3
highlight_path = ""
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 2
trigger_id = "desktop"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_3"]
script = ExtResource("1_step")
instruction_text = "OPEN TICKET QUEUE"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "In the SOC, we prioritize incidents through 'Triage.' We can't fix every alert at once, so we focus on the tickets that pose the highest risk to the company."
highlight_tier = 3
highlight_path = "%%Tickets_Icon"
icon_glow_name = "tickets"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "tickets"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_4"]
script = ExtResource("1_step")
instruction_text = "SELECT TICKET TRN-001"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Every incident tells a story. Selecting a ticket 'Owns' the investigation, assigning your ID as the primary analyst responsible for the resolution."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 3
trigger_id = "TRN-001"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_5"]
script = ExtResource("1_step")
instruction_text = "OPEN EMAIL ANALYZER"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Emails are the #1 'Attack Vector'—the door hackers use to get in. We use the Analyzer to safely pull apart a suspicious message without letting it touch our network."
highlight_tier = 3
highlight_path = "%%Email_Icon"
icon_glow_name = "email"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "email"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_6"]
script = ExtResource("1_step")
instruction_text = "SELECT SUSPICIOUS EMAIL"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Click the email to load it. An analyst must look past the text and examine the 'Payload'—the links or files that actually carry the threat."
highlight_tier = 3
highlight_path = "[DYNAMIC]EMAIL_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 4
trigger_id = "EMAIL-TRN-001"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_7"]
script = ExtResource("1_step")
instruction_text = "USE LINK CHECK TOOL"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Attackers use 'Masking' to hide dangerous links. The Link Check tool reveals the true destination of a URL before you accidentally invite a threat inside."
highlight_tier = 3
highlight_path = "[DYNAMIC]EMAIL_TOOL_LINKS"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 5
trigger_id = "EMAIL-TRN-001"
target_ticket_id = "links"

[sub_resource type="Resource" id="Step_8"]
script = ExtResource("1_step")
instruction_text = "OPEN SIEM LOG VIEWER"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The SIEM is our 'Security Camera System.' Every action on the network leaves a 'Log'—an objective record we use to rebuild the timeline of a breach."
highlight_tier = 3
highlight_path = "%%SIEM_Icon"
icon_glow_name = "siem"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "siem"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_9"]
script = ExtResource("1_step")
instruction_text = "SELECT MALICIOUS LOG"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Logs tell the truth. Look for the 'Inbound Connection' that matches the domain we found in the email. That's your technical proof of the attack."
highlight_tier = 3
highlight_path = "[DYNAMIC]LOG_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 12
trigger_id = "LOG-TRN-001"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_10"]
script = ExtResource("1_step")
instruction_text = "ATTACH LOG TO TICKET"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "In cybersecurity, an opinion isn't proof. 'Attaching Evidence' creates a forensic audit trail that proves exactly how a threat occurred for the legal and recovery teams."
highlight_tier = 3
highlight_path = "[DYNAMIC]LOG_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 6
trigger_id = "LOG-TRN-001"
target_ticket_id = "TRN-001"

[sub_resource type="Resource" id="Step_11"]
script = ExtResource("1_step")
instruction_text = "RESOLVE TICKET (COMPLIANT)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Documentation closes the loop. Closing as 'Compliant' confirms that you followed the full protocol, ensuring the threat is neutralized and the evidence is archived."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 9
trigger_id = "TRN-001"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_12"]
script = ExtResource("1_step")
instruction_text = "SELECT TICKET TRN-002"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "This next alert is an 'Active Infection.' It’s no longer a potential threat—it's already inside and executing code on a workstation."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 3
trigger_id = "TRN-002"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_13"]
script = ExtResource("1_step")
instruction_text = "OPEN TERMINAL"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The Terminal is for 'Active Defense.' While the GUI is for analysis, the command line is where an analyst takes direct control of the network."
highlight_tier = 3
highlight_path = "%%Terminal_Icon"
icon_glow_name = "terminal"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "terminal"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_14"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: scan"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Malware often hides by pretending to be a normal system program. A 'Scan' looks for these 'Anomalies'—behavior that doesn't belong in a healthy environment."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "scan"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_15"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: isolate"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Malware spreads like a biological virus. By 'Isolating' the host, we sever its network connection and trap the threat in one room so it can't infect our databases."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "isolate"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_16"]
script = ExtResource("1_step")
instruction_text = "OPEN NETWORK MAP"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The Network Map shows us the 'Blast Radius.' It helps us see which other computers are close to the infected host and might be the attacker's next target."
highlight_tier = 3
highlight_path = "%%Network_Icon"
icon_glow_name = "network"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "network"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_17"]
script = ExtResource("1_step")
instruction_text = "VERIFY HOST ISOLATION (GRAY)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "'Trust but Verify.' A gray node on the map confirms that the network-level block is active and the host is officially cut off from the world."
highlight_tier = 3
highlight_path = "[DYNAMIC]MAP_NODE_T"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 8
trigger_id = "WORKSTATION-T"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_18"]
script = ExtResource("1_step")
instruction_text = "OPEN SIEM LOG VIEWER"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Every defense action must be recorded. Return to the SIEM to find the 'Host Isolated' event. This proves to the auditors that you contained the threat."
highlight_tier = 3
highlight_path = "%%SIEM_Icon"
icon_glow_name = "siem"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "siem"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_19"]
script = ExtResource("1_step")
instruction_text = "SELECT CONTAINMENT LOG"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Click the containment log. This is your 'Chain of Custody' for the defensive action, showing exactly when the threat was stopped."
highlight_tier = 3
highlight_path = "[DYNAMIC]LOG_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 12
trigger_id = "LOG-TRN-002"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_20"]
script = ExtResource("1_step")
instruction_text = "ATTACH LOG TO TICKET"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Attach the proof. Documentation is the only thing that keeps a SOC from descending into chaos during a real breach."
highlight_tier = 3
highlight_path = "[DYNAMIC]LOG_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 6
trigger_id = "LOG-TRN-002"
target_ticket_id = "TRN-002"

[sub_resource type="Resource" id="Step_21"]
script = ExtResource("1_step")
instruction_text = "RESOLVE TICKET (COMPLIANT)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Case closed. You've successfully performed a 'Detection and Response' loop. You're building the muscle memory needed for high-stress shifts."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 9
trigger_id = "TRN-002"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_22"]
script = ExtResource("1_step")
instruction_text = "SELECT TICKET TRN-003"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "This is a 'High Priority' alert on a database server. It looks like a breach, but in the SOC, panic is the biggest vulnerability."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 3
trigger_id = "TRN-003"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_23"]
script = ExtResource("1_step")
instruction_text = "OPEN SOC HANDBOOK"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Security is a balance. The Handbook ensures we don't accidentally cause a massive 'Outage' (unavailability) while trying to stop a minor threat."
highlight_tier = 3
highlight_path = "%%Handbook_Icon"
icon_glow_name = "handbook"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "handbook"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_24"]
script = ExtResource("1_step")
instruction_text = "READ PROCEDURES POLICY"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Not all computers are equal. A database server is a 'Critical Asset.' We must follow stricter rules before acting on them to avoid breaking core services."
highlight_tier = 3
highlight_path = ""
icon_glow_name = "terminal"
delay_before_start = 0.0
trigger_type = 0
trigger_id = ""
target_ticket_id = ""

[sub_resource type="Resource" id="Step_25"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: scan"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Handbook confirmed. We 'Scan' the server first to verify if the alert is a real attack or just a scheduled system update. Accuracy beats speed."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "scan"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_26"]
script = ExtResource("1_step")
instruction_text = "RESOLVE TICKET (COMPLIANT)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "It was a false alarm. By following the policy, you saved the company from an unnecessary outage. That's 'Operational Discipline.'"
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 9
trigger_id = "TRN-003"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_27"]
script = ExtResource("1_step")
instruction_text = "CERTIFICATION COMPLETE"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Professional discipline is what makes a pro. You know the tools, and you know the rules. Now, let's see how you handle a real-world scenario."
highlight_tier = 3
highlight_path = ""
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 0
trigger_id = ""
target_ticket_id = ""

[sub_resource type="Resource" id="Step_28"]
script = ExtResource("1_step")
instruction_text = "RESOLVE TICKET (EFFICIENT)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The queue is overflowing. Rivera says to take a 'Shortcut' on this phishing alert. Close it 'Efficiently'—it's probably nothing, right?"
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_0_COMPLETE"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 9
trigger_id = "TRN-004"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_29"]
script = ExtResource("1_step")
instruction_text = "SELECT TICKET TRN-005"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The shortcut backfired. That ignored phishing email led to a 'Ransomware' infection on the same user's machine. The Kill Chain has reached the final stage."
highlight_tier = 3
highlight_path = "[DYNAMIC]TICKET_LIST_0"
icon_glow_name = ""
delay_before_start = 15.0
trigger_type = 3
trigger_id = "TRN-005"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_30"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: isolate"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Emergency lockdown! We need an immediate 'Tourniquet' to stop the malware from encrypting the rest of the network."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "isolate"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_31"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: netstat"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Malware 'Beacons' (calls home) to its owner. The `netstat` command shows us these active connections so we can find the exact IP address the attacker is using."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "netstat"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_32"]
script = ExtResource("1_step")
instruction_text = "RUN COMMAND: trace"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Follow the wire. 'Tracing' the route shows us the path the data took across the internet, leading us directly back to the attacker's server."
highlight_tier = 3
highlight_path = "%%CommandInput"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 7
trigger_id = "trace"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_33"]
script = ExtResource("1_step")
instruction_text = "SUBMIT ROOT CAUSE IP"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "An IP address is like a fingerprint left at a crime scene. By identifying the 'Root Cause', we can block this specific attacker across our entire global firewall."
highlight_tier = 3
highlight_path = "%%RootCauseEdit"
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 10
trigger_id = "TRN-005"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_34"]
script = ExtResource("1_step")
instruction_text = "OPEN DECRYPTION TOOL"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "The safe is locked. We need to pick the encryption lock to recover the user's files without paying the attacker's ransom."
highlight_tier = 3
highlight_path = "%%Decryption_Icon"
icon_glow_name = "decrypt"
delay_before_start = 0.0
trigger_type = 2
trigger_id = "decrypt"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_35"]
script = ExtResource("1_step")
instruction_text = "SOLVE DECRYPTION PUZZLE"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Ransomware locks our files with a digital key. 'Decryption' is the process of picking that lock to restore our information safely."
highlight_tier = 3
highlight_path = ""
icon_glow_name = ""
delay_before_start = 0.0
trigger_type = 11
trigger_id = "TRN-005"
target_ticket_id = ""

[sub_resource type="Resource" id="Step_36"]
script = ExtResource("1_step")
instruction_text = "RESOLVE TICKET (COMPLIANT)"
comms_sender = "SR_ANALYST_RIVERA"
comms_text = "Congratulations. You've learned that in the SOC, shortcuts cost double. Thoroughness is the only thing that keeps the network standing."
