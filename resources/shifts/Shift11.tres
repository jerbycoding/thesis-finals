[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 11: Thursday (Paranoia)"
shift_id = "shift_week2_thursday"
shift_summary = "Active sabotage. An internal mole is using Wiper scripts to delete security logs in real-time. The analyst must move fast to preserve forensic evidence."
cyber_context = "Anti-Forensics techniques, such as Wipers, are used by attackers to delete logs and hide their presence. Analysts must use rapid containment (Isolation) to freeze the system state before the evidence is permanently erased."
briefing_dialogue_id = "week2_thursday"
event_sequence = [
	{"time": 30, "event": "spawn_mole_hunt", "type": "spawn_ticket", "ticket_id": "MOLE-HUNT-001"},
	{"time": 90, "event": "analyst_accusation", "type": "npc_interaction", "npc_id": "senior_analyst", "dialogue_id": "accusation"},
	{"time": 210, "event": "spawn_log_wiper", "type": "spawn_ticket", "ticket_id": "LOG-WIPER-001"},
	{"time": 330, "event": "spawn_sabotage", "type": "spawn_ticket", "ticket_id": "SABOTAGE-001"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "false_flag_logs", "type": "system_event", "event_id": "FALSE_FLAG", "duration": 45.0},
	{"event": "gossip_mole", "type": "system_event", "event_id": "GOSSIP_FLOOD", "duration": 60.0}
]
next_shift_id = "shift_week2_friday"
