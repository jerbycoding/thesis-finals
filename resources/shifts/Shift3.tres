[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 3: Wednesday (Outbreak)"
shift_id = "shift_wednesday"
shift_summary = "An active outbreak scenario. Malware has entered the network and is attempting to move laterally across workstations while a Ransomware payload targets the Finance servers."
cyber_context = "Lateral Movement is the process where an attacker pivots from a compromised workstation to a high-value server. Rapid containment (Isolation) is necessary to stop the pivot before data exfiltration occurs."
briefing_dialogue_id = "briefing_third_shift"
event_sequence = [
	{"time": 30, "event": "spawn_malware", "type": "spawn_ticket", "ticket_id": "MALWARE-CONTAIN-001"},
	{"time": 90, "event": "analyst_checkin", "type": "npc_interaction", "npc_id": "senior_analyst", "dialogue_id": "wednesday_outbreak"},
	{"time": 150, "event": "start_lateral", "type": "system_event", "event_id": "LATERAL_MOVEMENT", "duration": 180.0},
	{"time": 270, "event": "spawn_phish_3", "type": "spawn_ticket", "ticket_id": "PHISH-003"},
	{"time": 360, "event": "spawn_ransom", "type": "spawn_ticket", "ticket_id": "RANSOM-001"},
	{"time": 450, "event": "shift_end_convo", "type": "npc_interaction", "npc_id": "ciso", "dialogue_id": "shift_end"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "crypto_outbreak", "type": "spawn_ticket", "ticket_id": "CRYPTOMINER-HUNT-001"},
	{"event": "cpu_thermal_spike", "type": "system_event", "event_id": "CRYPTO_SPIKE", "duration": 60.0},
	{"event": "infrastructure_strain", "type": "system_event", "event_id": "ISP_THROTTLING", "duration": 45.0},
	{"event": "db_query_lag", "type": "system_event", "event_id": "SIEM_LAG", "duration": 20.0},
	{"event": "analyst_tip", "type": "npc_interaction", "npc_id": "senior_analyst", "dialogue_id": "default"}
]
next_shift_id = "shift_thursday"
