[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 9: Tuesday (System Instability)"
shift_id = "shift_week2_tuesday"
briefing_dialogue_id = "default"
event_sequence = [
	{"time": 10, "event": "siem_crash", "type": "system_event", "event_id": "SIEM_LAG", "duration": 120.0},
	{"time": 30, "event": "spawn_supply_corrupt", "type": "spawn_ticket", "ticket_id": "SUPPLY-CHAIN-004"},
	{"time": 90, "event": "spawn_dns_spoof", "type": "spawn_ticket", "ticket_id": "DNS-SPOOF-001"},
	{"time": 180, "event": "spawn_service_flap", "type": "spawn_ticket", "ticket_id": "SERVICE-FLAP-001"},
	{"time": 300, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "ghost_log", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-001"},
	{"event": "terminal_glitch", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 5.0}
]
next_shift_id = "shift_week2_wednesday"
