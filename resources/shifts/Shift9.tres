[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 9: Tuesday (System Instability)"
shift_id = "shift_week2_tuesday"
shift_summary = "Technical disruptions across the subnet. The SIEM is reporting inconsistent 'Ghost Logs' and a major software vendor has reported a supply chain compromise."
cyber_context = "Integrity Monitoring ensures that logs and files are original and untampered. Supply Chain attacks are devastating because they exploit the trust between a company and its software providers (e.g., NetCore recall)."
briefing_dialogue_id = "week2_tuesday"
event_sequence = [
	{"time": 15, "event": "siem_crash", "type": "system_event", "event_id": "SIEM_LAG", "duration": 300.0},
	{"time": 60, "event": "spawn_supply_corrupt", "type": "spawn_ticket", "ticket_id": "SUPPLY-CHAIN-004"},
	{"time": 180, "event": "spawn_dns_spoof", "type": "spawn_ticket", "ticket_id": "DNS-SPOOF-001"},
	{"time": 330, "event": "spawn_service_flap", "type": "spawn_ticket", "ticket_id": "SERVICE-FLAP-001"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "ghost_log", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-001"},
	{"event": "terminal_glitch", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 3.0}
]
next_shift_id = "shift_week2_wednesday"
threat_title = "SUPPLY_CHAIN"
threat_description = "An attack targeting a third-party vendor or software provider to gain access to their downstream corporate clients."
threat_impact = "Victims unintentionally install 'poisoned' updates from trusted vendors, leading to a massive, trusted breach."
threat_indicators = ["Checksum mismatches in software updates.", "Unusual traffic to verified vendor domains.", "NetCore device recalls or firmware alerts."]
