	{"time": 10, "event": "start_ddos", "type": "system_event", "event_id": "DDOS_ATTACK", "duration": 300.0},
	{"time": 30, "event": "spawn_kill_switch", "type": "spawn_ticket", "ticket_id": "KILL-SWITCH-001"},
	{"time": 60, "event": "ciso_speech", "type": "npc_interaction", "npc_id": "ciso", "dialogue_id": "stand_ground"},
	{"time": 90, "event": "spawn_meltdown", "type": "spawn_ticket", "ticket_id": "CORE-MELTDOWN-001"},
	{"time": 150, "event": "spawn_admin_lock", "type": "spawn_ticket", "ticket_id": "ADMIN-LOCKOUT-001"},
