[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 12: Friday (Total War)"
shift_id = "shift_week2_friday"
shift_summary = "Total systemic collapse. The SOC is under full siege with terminal lockouts and backup deletions. The analyst must use all available tools to hold the line."
cyber_context = "Incident Response at scale requires resilience. When automated systems (firewalls, EDR) are overwhelmed, the final line of defense is the analyst's ability to manually verify and isolate threats under extreme pressure."
briefing_dialogue_id = "week2_friday"
event_sequence = [
	{"time": 10, "event": "start_apocalypse", "type": "system_event", "event_id": "ZERO_DAY", "duration": 540.0},
	{"time": 10, "event": "start_lag", "type": "system_event", "event_id": "SIEM_LAG", "duration": 540.0},
	{"time": 10, "event": "start_ddos", "type": "system_event", "event_id": "DDOS_ATTACK", "duration": 540.0},
	{"time": 30, "event": "spawn_patient_zero", "type": "spawn_ticket", "ticket_id": "ZERODAY-001"},
	{"time": 60, "event": "spawn_kill_switch", "type": "spawn_ticket", "ticket_id": "KILL-SWITCH-001"},
	{"time": 120, "event": "spawn_poisoned_deps", "type": "spawn_ticket", "ticket_id": "ZERODAY-004"},
	{"time": 150, "event": "ciso_speech", "type": "npc_interaction", "npc_id": "ciso", "dialogue_id": "stand_ground"},
	{"time": 210, "event": "spawn_gateway_breach", "type": "spawn_ticket", "ticket_id": "ZERODAY-002"},
	{"time": 240, "event": "spawn_meltdown", "type": "spawn_ticket", "ticket_id": "CORE-MELTDOWN-001"},
	{"time": 330, "event": "spawn_cascade", "type": "spawn_ticket", "ticket_id": "ZERODAY-003"},
	{"time": 360, "event": "spawn_admin_lock", "type": "spawn_ticket", "ticket_id": "ADMIN-LOCKOUT-001"},
	{"time": 480, "event": "spawn_zero_click", "type": "spawn_ticket", "ticket_id": "ZERODAY-005"},
	{"time": 600, "event": "shift_end", "type": "shift_end", "failure_type": "victory"} 
]
random_event_pool = [
	{"event": "panic_noise", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-002"},
	{"event": "power_surge", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 3.0}
]
next_shift_id = "" # End of Content (Victory)
threat_title = "TOTAL_WAR_SIEGE"
threat_description = "A multi-vector 'Apocalypse Protocol' assault designed to simultaneously destroy every layer of corporate infrastructure."
threat_impact = "Total business liquidation; 100% loss of operational capacity and organizational integrity."
threat_indicators = ["Concurrent DDoS, Wiper, and Ransomware.", "Total administrative lockout from SOC accounts.", "Physical HVAC override causing thermal meltdowns."]
