[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 6: Saturday (Infrastructure Audit)"
shift_id = "shift_saturday"
shift_summary = "A scheduled physical infrastructure audit. The analyst must navigate the 3D Network Hub to verify router integrity and calibrate signal nodes."
cyber_context = "Cybersecurity isn't just digital. Physical Access Controls and Infrastructure Audits ensure that network hardware hasn't been tampered with or bypassed by an on-site adversary."
briefing_dialogue_id = "briefing_saturday"
event_sequence = [
	{"time": 10, "event": "audit_start", "type": "system_event", "event_id": "MAINTENANCE_WINDOW", "duration": 300.0},
	{"time": 300, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = []
next_shift_id = "shift_sunday"
minigame_type = "AUDIT"
required_floor = -2