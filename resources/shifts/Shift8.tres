[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 8: Monday (Inheritance)"
shift_id = "shift_week2_monday"
shift_summary = "Persistence identified. Threats from the previous week reappear in more sophisticated forms. The analyst must identify inherited indicators of compromise."
cyber_context = "Persistence is the goal of Advanced Persistent Threats (APTs). If an analyst only cleans the symptoms (Malware) but misses the root cause (Backdoor), the attacker will inevitably return with evolved tools."
briefing_dialogue_id = "week2_intro"
event_sequence = [
	{"time": 30, "event": "spawn_legacy_phish", "type": "spawn_ticket", "ticket_id": "PHISH-LEGACY-001"},
	{"time": 90, "event": "analyst_checkin", "type": "npc_interaction", "npc_id": "senior_analyst", "dialogue_id": "week2_checkin"},
	{"time": 180, "event": "spawn_auth_spike", "type": "spawn_ticket", "ticket_id": "AUTH-SPIKE-001"},
	{"time": 270, "event": "spawn_poly_malware", "type": "spawn_ticket", "ticket_id": "MALWARE-POLY-001"},
	{"time": 390, "event": "spawn_ransom_echo", "type": "spawn_ticket", "ticket_id": "RANSOM-ECHO-001"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "polymorphic_noise", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-POLY-001"},
	{"event": "siem_glitch", "type": "system_event", "event_id": "SIEM_LAG", "duration": 45.0},
	{"event": "isp_throttling", "type": "system_event", "event_id": "ISP_THROTTLING", "duration": 60.0}
]
next_shift_id = "shift_week2_tuesday"
