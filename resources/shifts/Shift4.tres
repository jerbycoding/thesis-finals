[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 4: Thursday (Betrayal)"
shift_id = "shift_thursday"
shift_summary = "Internal anomalies detected. The analyst must investigate potential insider threats and the use of unsanctioned Shadow IT cloud storage on the marketing subnet."
cyber_context = "Insider Threats are among the most difficult to detect because they involve legitimate credentials. Shadow IT represents a major data leak risk as corporate data moves to unmanaged personal accounts outside SOC visibility."
briefing_dialogue_id = "briefing_thursday"
event_sequence = [
	{"time": 30, "event": "spawn_auth_3", "type": "spawn_ticket", "ticket_id": "AUTH-003"},
	{"time": 90, "event": "ciso_checkin", "type": "npc_interaction", "npc_id": "ciso", "dialogue_id": "thursday_betrayal"},
	{"time": 180, "event": "spawn_insider", "type": "spawn_ticket", "ticket_id": "INSIDER-001"},
	{"time": 270, "event": "spawn_shadow_it_1", "type": "spawn_ticket", "ticket_id": "SHADOW-IT-001"},
	{"time": 390, "event": "spawn_spear_3", "type": "spawn_ticket", "ticket_id": "SPEAR-PHISH-003"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "credentials_leak_noise", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-001"},
	{"event": "log_obfuscation", "type": "system_event", "event_id": "FALSE_FLAG", "duration": 45.0},
	{"event": "rumor_mill", "type": "system_event", "event_id": "GOSSIP_FLOOD", "duration": 60.0},
	{"event": "unexplained_blackout", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 3.0},
	{"event": "senior_analyst_suspicion", "type": "npc_interaction", "npc_id": "senior_analyst", "dialogue_id": "default"}
]
next_shift_id = "shift_friday"