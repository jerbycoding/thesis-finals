[gd_resource type="Resource" script_class="ShiftResource" load_steps=3 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]
[ext_resource type="Resource" uid="uid://sundayrecoveryres1" path="res://resources/minigames/SundayRecovery.tres" id="2_recovery"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 7: Sunday (Hardware Recovery)"
shift_id = "shift_sunday"
shift_summary = "Emergency hardware recovery. Following the Friday crisis, several server blades have failed. The analyst must manually replace hardware and synchronize the RAID parity."
cyber_context = "Disaster Recovery (DR) and High Availability are vital for business continuity. Rebuilding storage arrays (RAID) ensures that forensic data and operational backups are restored after a destructive attack."
briefing_dialogue_id = "briefing_sunday"
event_sequence = [
	{"time": 10, "event": "recovery_start", "type": "system_event", "event_id": "RECOVERY_WINDOW", "duration": 300.0},
	{"time": 300, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = []
next_shift_id = "shift_week2_monday"
threat_title = "STORAGE_FAILURE"
threat_description = "The mechanical or logical failure of data storage arrays, often following a destructive Wiper or Ransomware attack."
threat_impact = "Permanent loss of forensic history and backups; prevents the organization from reconstructing the incident timeline."
threat_indicators = ["Disk parity errors in RAID configurations.", "Mechanical blade failure alerts in the vault.", "Inability to mount encrypted backup volumes."]
minigame_type = "RECOVERY"
required_floor = -1
recovery_config = ExtResource("2_recovery")