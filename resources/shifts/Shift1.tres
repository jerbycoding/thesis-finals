[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3 uid="uid://b3eg2snqt6wls"]

[ext_resource type="Script" uid="uid://d0o2ouygja3cr" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 1: Monday (Active Monitoring)"
shift_id = "shift_monday"
shift_summary = "Standard entry monitoring. Analysts must triage reported phishing emails and manually verify technical indicators in the SIEM logs."
cyber_context = "Phishing is the #1 threat vector for corporate breaches. Understanding how to differentiate between a spoofed external sender and an internal service account is the foundation of a SOC analyst's career."
briefing_dialogue_id = "briefing_01"
event_sequence = Array[Dictionary]([{
"event": "spawn_phish",
"ticket_id": "PHISH-001",
"time": 30,
"type": "spawn_ticket"
}, {
"dialogue_id": "monday_morning",
"event": "analyst_checkin",
"npc_id": "senior_analyst",
"time": 90,
"type": "npc_interaction"
}, {
"event": "spawn_auth",
"ticket_id": "AUTH-FAIL-GENERIC",
"time": 150,
"type": "spawn_ticket"
}, {
"event": "spawn_maint",
"ticket_id": "SYS-MAINT-GENERIC",
"time": 270,
"type": "spawn_ticket"
}, {
"event": "spawn_spear",
"ticket_id": "SPEAR-PHISH-001",
"time": 360,
"type": "spawn_ticket"
}, {
"dialogue_id": "shift_end",
"event": "ciso_end",
"npc_id": "ciso",
"time": 420,
"type": "npc_interaction"
}, {
"event": "shift_end",
"time": 600,
"type": "shift_end"
}])
random_event_pool = Array[Dictionary]([{
"event": "random_login_fail",
"ticket_id": "AUTH-FAIL-GENERIC",
"type": "spawn_ticket"
}, {
"event": "account_lockout_noise",
"ticket_id": "TICKET-NOISE-001",
"type": "spawn_ticket"
}, {
"duration": 15.0,
"event": "minor_siem_lag",
"event_id": "SIEM_LAG",
"type": "system_event"
}, {
"duration": 30.0,
"event": "isp_blip",
"event_id": "ISP_THROTTLING",
"type": "system_event"
}, {
"duration": 60.0,
"event": "internal_gossip",
"event_id": "GOSSIP_FLOOD",
"type": "system_event"
}, {
"dialogue_id": "default",
"event": "peer_checkin",
"npc_id": "senior_analyst",
"type": "npc_interaction"
}])
next_shift_id = "shift_tuesday"
threat_title = "PHISHING"
threat_description = "Phishing is a type of social engineering where an attacker sends a fraudulent message designed to trick a person into revealing sensitive information or deploying malicious software on their infrastructure."
threat_impact = "Phishing campaigns often lead to credential theft, unauthorized network access, and the deployment of ransomware. A single successful phish can compromise an entire corporate hierarchy."
threat_indicators = Array[String](["Mismatched 'From' display names vs actual email addresses.", "Urgent or threatening language demanding immediate action.", "Links that point to suspicious or non-standard domains.", "Unexpected attachments with unusual file extensions."])
minigame_type = "NONE"
required_floor = 1
