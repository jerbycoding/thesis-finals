[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 5: Friday (Zero Day)"
shift_id = "shift_friday"
shift_summary = "A massive zero-day offensive. The SOC is hit by concurrent DDoS attacks and critical server encryption. Success requires prioritizing server containment over minor alerts."
cyber_context = "Zero-Day exploits target vulnerabilities unknown to vendors. During a major crisis, Triage is essential: analysts must defend high-value assets (Finance/Web) even if it means allowing lower-priority devices to fail."
briefing_dialogue_id = "briefing_friday"
event_sequence = [
	{"time": 10, "event": "zero_day_start", "type": "system_event", "event_id": "ZERO_DAY", "duration": 300.0},
	{"time": 60, "event": "spawn_exfil", "type": "spawn_ticket", "ticket_id": "DATA-EXFIL-001"},
	{"time": 180, "event": "spawn_ransom_2", "type": "spawn_ticket", "ticket_id": "RANSOM-002"},
	{"time": 300, "event": "ddos_start", "type": "system_event", "event_id": "DDOS_ATTACK", "duration": 180.0},
	{"time": 300, "event": "spawn_ddos", "type": "spawn_ticket", "ticket_id": "DDOS-MITIGATION-001"},
	{"time": 420, "event": "maybe_spawn_redemption", "type": "spawn_ticket", "ticket_id": "BLACK-TICKET-REDEMPTION"},
	{"time": 600, "event": "final_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "system_panic_glitch", "type": "system_event", "event_id": "SIEM_LAG", "duration": 20.0},
	{"event": "packet_storm", "type": "system_event", "event_id": "DDOS_ATTACK", "duration": 60.0},
	{"event": "grid_instability", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 3.0},
	{"event": "global_latency_spike", "type": "system_event", "event_id": "ISP_THROTTLING", "duration": 30.0},
	{"event": "urgent_noise", "type": "spawn_ticket", "ticket_id": "TICKET-NOISE-002"}
]
next_shift_id = "shift_saturday"
threat_title = "ZERO_DAY_EXPLOIT"
threat_description = "An attack that exploits a previously unknown software vulnerability for which no patch or fix yet exists."
threat_impact = "Can cause widespread systemic failure. Standard EDR and Antivirus signatures are ineffective during the initial breach."
threat_indicators = ["Rapid encryption of production servers.", "Simultaneous DDoS traffic on core gateways.", "Unexplained crashes of critical services."]