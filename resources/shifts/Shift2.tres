[gd_resource type="Resource" script_class="ShiftResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/ShiftResource.gd" id="1_shift"]

[resource]
script = ExtResource("1_shift")
shift_name = "Shift 2: Tuesday (Noise)"
shift_id = "shift_tuesday"
shift_summary = "An increase in operational noise. Attackers use Social Engineering and False Flag logs to overwhelm and distract the analyst from real threats."
cyber_context = "Log Obfuscation is a defensive counter-measure used by attackers to hide their tracks. In a high-noise environment, analysts must rely on specific search queries rather than manual scrolling to maintain situational awareness."
briefing_dialogue_id = "briefing_second_shift"
event_sequence = [
	{"time": 30, "event": "spawn_social", "type": "spawn_ticket", "ticket_id": "SOCIAL-001"},
	{"time": 90, "event": "it_checkin", "type": "npc_interaction", "npc_id": "it_support", "dialogue_id": "tuesday_complaint"},
	{"time": 150, "event": "spawn_supply_chain_1", "type": "spawn_ticket", "ticket_id": "SUPPLY-CHAIN-001"},
	{"time": 240, "event": "log_flood", "type": "system_event", "event_id": "FALSE_FLAG", "duration": 90.0},
	{"time": 330, "event": "spawn_spear_2", "type": "spawn_ticket", "ticket_id": "SPEAR-PHISH-002"},
	{"time": 420, "event": "shift_end_talk", "type": "npc_interaction", "npc_id": "ciso", "dialogue_id": "shift_end"},
	{"time": 600, "event": "shift_end", "type": "shift_end"}
]
random_event_pool = [
	{"event": "routine_patching", "type": "spawn_ticket", "ticket_id": "SYS-MAINT-GENERIC"},
	{"event": "siem_bottleneck", "type": "system_event", "event_id": "SIEM_LAG", "duration": 30.0},
	{"event": "gossip_distraction", "type": "system_event", "event_id": "GOSSIP_FLOOD", "duration": 45.0},
	{"event": "unstable_power", "type": "system_event", "event_id": "POWER_FLICKER", "duration": 3.0},
	{"event": "unauthorized_script_noise", "type": "spawn_ticket", "ticket_id": "MALWARE-002"},
	{"event": "it_complaint", "type": "npc_interaction", "npc_id": "it_support", "dialogue_id": "default"}
]
next_shift_id = "shift_wednesday"
threat_title = "LOG_OBFUSCATION"
threat_description = "The intentional generation of 'False Flag' events to flood security logs with benign or misleading data."
threat_impact = "Analysts become distracted by high-volume noise, leading to critical alerts being overlooked or timed out."
threat_indicators = ["Sudden surge in 'Info' level logs.", "Repeating generic error patterns.", "Alerts originating from non-critical subnets."]
