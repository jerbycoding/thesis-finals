[resource]
script = ExtResource("1_ticket")
ticket_id = "PHISH-001"
title = "Phishing Campaign Alert"
description = "Alert: Multiple users report a suspicious email with the subject 'URGENT: Verify Your Account'. 

[b]Instruction:[/b] Open the [color=cyan]Email Analyzer[/color] and use the [b]Link Check[/b] tool. It will reveal a hidden Malicious IP address. Once you have the IP, open the [b]SIEM Viewer[/b] and search for that IP to see if any users actually clicked it. Attach the log as evidence."
severity = "Medium"
category = "Phishing"
steps = Array[String](["Use Link Check in Email Analyzer", "Identify malicious IP address", "Search SIEM for IP and attach log"])
required_tool = "siem"
base_time = 300.0
