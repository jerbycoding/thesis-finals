[ext_resource type="Script" uid="uid://ccptkdfdnunvq" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "AUTH-BRUTE-LOCAL"
title = "Critical Alert: Internal Account Brute-Force"
description = "CRITICAL: Internal Brute-Force Attack. A computer inside our own office is trying to guess passwords for other users. This usually means that machine is infected with a 'worm'. 

[b]Instruction:[/b] Use the SIEM to identify the Source Workstation (the machine doing the attacking). Once found, open the SOC Terminal and use the [color=#006CFF]isolate [hostname][/color] command to cut its network access."
severity = "High"
category = "Unauthorized Access"
steps = Array[String](["Identify attack source in SIEM", "Verify targeting patterns", "Isolate MARKETING-WS-02 via Terminal"])
required_tool = "terminal"
base_time = 240.0
hidden_risks = Array[String](["data_breach"])
required_log_ids = Array[String](["LOG-BRUTE-LOCAL"])
is_ambient_noise = false
required_host_isolation = "MARKETING-WS-02"
required_host_restoration = ""
required_root_cause = ""
on_complete_event = ""
kill_chain_path = "Internal Compromise"
kill_chain_stage = 1
