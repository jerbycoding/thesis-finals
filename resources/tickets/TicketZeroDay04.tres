category = "Malware"
steps = ["Query SysMon for encoded PowerShell execution strings.", "Identify the compromised dependency repository.", "Block the outbound C2 communication at the firewall level."]
required_tool = "siem"
base_time = 300.0
hidden_risks = ["backdoor_persistence"]
required_log_ids = ["LOG-ZD-02B"]
is_ambient_noise = false
required_host_isolation = ""
required_host_restoration = ""
on_complete_event = ""
kill_chain_path = "Zero-Day Apocalypse"
