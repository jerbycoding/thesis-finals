[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "ZERODAY-004"
title = "Obfuscated Payload Executing in Memory — Supply Chain"
description = "EDR caught an obfuscated PowerShell payload executing dynamically in memory on {host}, assigned to {victim}. Threat intel suggests a compromised Node.js package from {malicious_url} is downloading a secondary stager to communicate with {ip}."
