[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" uid="uid://ccptkdfdnunvq" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "MOLE-HUNT-001"
title = "Conflicting Access Logs"
description = "ALERT: Admin Login Anomaly. A system reboot was triggered using the 'admin' account, but IT Support claims they were asleep. 

[b]Instruction:[/b] Search the SIEM for 'admin'. Identify the IP address used for the 02:00 AM login. Type that IP into the [b]Root Cause[/b] box below to confirm if it was an external attacker."
severity = "High"
category = "Insider Threat"
steps = Array[String](["Search SIEM for 'admin' activity", "Verify IP location of 02:00 AM login", "Enter IP in Root Cause box"])
required_tool = "siem"
base_time = 180.0
hidden_risks = ["Trusting IT Support without verification"]
required_log_ids = ["LOG-MOLE-ADMIN-01"]
required_host_isolation = ""
required_host_restoration = ""
required_root_cause = "{ip}"
on_complete_event = ""
kill_chain_path = "Insider Sabotage"
kill_chain_stage = 2
