[resource]
script = ExtResource("2_ticket")
ticket_id = "SHADOW-IT-002"
title = "Escalation: Large Data Transfer"
description = "CRITICAL: Live Data Leak. A workstation is uploading gigabytes of data to a personal cloud account. 

[b]Instruction:[/b] This is a policy violation in progress. Open the SOC Terminal and type [b]isolate MARKETING-WS-02[/b] to stop the upload immediately."
severity = "High"
category = "Data Breach"
steps = Array[String](["Verify transfer size in SIEM", "Identify exfiltrated files", "Isolate MARKETING-WS-02 via Terminal"])
required_tool = "terminal"
base_time = 150.0
required_log_ids = ["LOG-SHADOW-002"]
required_host_isolation = "MARKETING-WS-02"
required_host_restoration = ""
required_root_cause = ""
on_complete_event = ""
kill_chain_path = "Shadow IT"
kill_chain_stage = 2
escalation_ticket = ExtResource("1_escalation")
