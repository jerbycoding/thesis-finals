[gd_resource type="Resource" script_class="TicketResource" load_steps=3 format=3]

[ext_resource type="Resource" path="res://resources/tickets/TicketSupplyOutbreak.tres" id="1_escalation"]
[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="2_ticket"]

[resource]
script = ExtResource("2_ticket")
ticket_id = "SUPPLY-CHAIN-002"
title = "Escalation: Unauthorized Beaconing"
description = "Alert: An internal server ({victim_host}) has been detected beaconing to a new, unrecognized IP address. This behavior is consistent with a backdoor installation and command-and-control (C2) communication.

The timing suggests a possible link to the recent supply chain account compromise. Immediate isolation and forensic analysis of the server are required."
severity = "High"
category = "Malware"
steps = ["Identify the beaconing internal server", "Isolate the server to prevent further C2 communication", "Analyze the server's traffic logs for data exfiltration"]
required_tool = "terminal"
base_time = 180.0
required_log_ids = ["LOG-SUPPLY-002"]
kill_chain_path = "Supply Chain"
kill_chain_stage = 2
escalation_ticket = ExtResource("1_escalation")
