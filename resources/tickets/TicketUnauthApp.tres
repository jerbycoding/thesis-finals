[gd_resource type="Resource" script_class="TicketResource" load_steps=3 format=3]

[ext_resource type="Resource" path="res://resources/tickets/TicketDataMove.tres" id="1_escalation"]
[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="2_ticket"]

[resource]
script = ExtResource("2_ticket")
ticket_id = "SHADOW-IT-001"
title = "Policy Violation: Unauthorized Cloud App"
description = "Network monitoring has detected repeated outbound traffic to 'dropbox.com' from a workstation in the Marketing department. Corporate policy strictly prohibits the use of unsanctioned cloud storage for company data.

Investigate the source and identify the user. This is a potential starting point for data exfiltration."
severity = "Low"
category = "Unauthorized Access"
steps = ["Identify Marketing workstation in SIEM", "Verify traffic destination", "Issue policy reminder via email"]
required_tool = "siem"
base_time = 180.0
required_log_ids = ["LOG-SHADOW-001"]
kill_chain_path = "Shadow IT"
kill_chain_stage = 1
escalation_ticket = ExtResource("1_escalation")
