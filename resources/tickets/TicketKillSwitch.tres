[resource]
script = ExtResource("1_ticket")
ticket_id = "KILL-SWITCH-001"
title = "CRITICAL: Backup Wipe Initiated"
description = "EXTINCTION ALERT: Attackers are deleting our server backups. 

[b]Instruction:[/b] You must act fast. Find the attacker's IP in the SIEM logs and type it into the [b]Root Cause[/b] box below. This will terminate their remote session and save the data."
severity = "Critical"
category = "Data Breach"
steps = Array[String](["Identify 'rm -rf' command in SIEM", "Locate Attacker IP address", "Enter IP in Root Cause box"])
required_tool = "terminal"
base_time = 90.0
hidden_risks = ["Hesitation"]
required_log_ids = ["LOG-KILL-SWITCH-001"]
required_host_isolation = ""
required_host_restoration = ""
required_root_cause = "{attacker_ip}"
on_complete_event = ""
kill_chain_path = "Total Collapse"
kill_chain_stage = 3
