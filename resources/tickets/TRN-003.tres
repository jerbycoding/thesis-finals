[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "TRN-003"
title = "CRITICAL: Database Anomaly"
description = "High-priority alert: DB-SRV-01 is exhibiting unusual CPU spikes and high network traffic. 

[b]Senior Analyst Note:[/b] It looks like a breach! We might need to isolate it fast. But wait—that's a critical server. Always check your [color=cyan]Handbook[/color] before acting on Critical Assets."
severity = "Critical"
category = "Unauthorized Access"
steps = ["Consult Handbook", "Verify DB-SRV-01 via Scan", "Resolve Case"]
required_tool = "handbook"
base_time = 600.0
hidden_risks = []
