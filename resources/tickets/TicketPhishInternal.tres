[resource]
script = ExtResource("1_ticket")
ticket_id = "PHISH-INTERNAL-001"
title = "Investigation: Reported Deceptive Internal Email"
description = "ALERT: Internal Spoofing Detected. Someone is sending emails that look like they come from our IT department, but the domain is wrong. 

[b]Instruction:[/b] Use the Email Analyzer to find the sender's real domain. Then, search the SIEM logs for that domain to see if any users actually interacted with it. Attach the log as evidence."
