[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "USER-COMPLAINT-FOLLOWUP"
title = "User Complaint Investigation"
description = "Stakeholder feedback: A user has filed a [color=#006CFF]COMPLAINT[/color] regarding a recent security action. Review the report and justify the procedural deviation."
severity = "Low"
category = "General"
steps = ["Review user complaint email", "Cross-reference with system logs", "Apologize or justify action"]
required_tool = "email"
base_time = 180.0
