[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "DATA-EXFIL-001"
title = "Data Exfiltration Alert"
description = "Suspicious outbound traffic detected. Email contains external IP address. Cross-reference email and SIEM logs to identify data breach."
severity = "Critical"
category = "Data Breach"
steps = ["Check email for suspicious IP address", "Search IP in SIEM logs", "Use Terminal to check host status if needed"]
required_tool = "none"
base_time = 360.0
hidden_risks = ["Data already exfiltrated → breach confirmed"]
required_log_ids = ["LOG-EXFIL-001", "LOG-NETWORK-001"]
