[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "AUTH-003"
title = "Auth Anomaly: Exec Account"
description = "Multiple failed login attempts detected for an executive-level account ({victim_name}) originating from an internal IP address. This could be an insider attempting to escalate privileges."
severity = "High"
category = "Authentication"
steps = ["Identify the source internal IP", "Cross-reference IP with known hostnames", "Flag for potential insider threat investigation"]
required_tool = "siem"
base_time = 200.0
required_log_ids = ["LOG-AUTH-004"]
kill_chain_path = "The Data Breach"
kill_chain_stage = 1
