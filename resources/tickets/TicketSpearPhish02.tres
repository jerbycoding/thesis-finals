[gd_resource type="Resource" script_class="TicketResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/tickets/TicketResource.gd" id="1_ticket"]

[resource]
script = ExtResource("1_ticket")
ticket_id = "SPEAR-PHISH-002"
title = "Spear Phish: Fake Invoice for CFO"
description = "A high-priority [color=#006CFF]INVOICE[/color] has been flagged by the CFO's office. Verify the authenticity of the sender and analyze the attachment for embedded malicious logic."
severity = "High"
category = "Phishing"
steps = ["Inspect email headers for spoofing", "Scan attachment for malware", "Quarantine email if malicious"]
required_tool = "email"
base_time = 220.0
hidden_risks = ["missed_attachment_scan"]
required_log_ids = ["LOG-SPEAR-002"]
kill_chain_path = "Malware Outbreak"
kill_chain_stage = 1
