[gd_resource type="Resource" script_class="EmailResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/EmailResource.gd" id="1_email"]

[resource]
script = ExtResource("1_email")
email_id = "EMAIL-SUPPLY-CORRUPT"
sender = "IT-Advisory@netcore-updates.biz"
subject = "URGENT: Force Update Required for Core Routers"
body = "To all infrastructure staff,

Due to a critical vulnerability in netcore kernel v4.4.1, all routers must be force-upgraded to v4.4.2-logic-patch immediately. 

[Download logic-patch.bin.exe]

Note: This update bypasses the standard SIEM validation cycle for speed."
attachments = ["logic-patch.bin.exe"]
headers = {"status": {"dkim": "FAIL", "dmarc": "PASS", "spf": "FAIL"}}
is_malicious = true
is_urgent = true
clues = ["bad_attachment", "spoofed_sender"]
related_ticket = "SUPPLY-CHAIN-004"
suspicious_domain = "netcore-updates.biz"
