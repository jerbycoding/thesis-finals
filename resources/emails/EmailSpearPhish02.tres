[gd_resource type="Resource" script_class="EmailResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/EmailResource.gd" id="1_email"]

[resource]
script = ExtResource("1_email")
email_id = "EMAIL-SPEAR-002"
sender = "accounts@quickbooks.finance"
subject = "FW: Overdue Invoice"
body = "Hi team,\n\nPlease see attached invoice that is overdue. Let me know if you have any questions.\n\nThanks,\n'Vendor Name'"
attachments = ["invoice.exe"]
headers = {"status": {"spf": "FAIL", "dkim": "PASS", "dmarc": "PASS"}, "from_domain": "quickbooks.finance", "reply_to": "accounts@quickbooks.finance"}
is_malicious = true
is_urgent = true
clues = ["bad_attachment", "spoofed_sender"]
related_ticket = "SPEAR-PHISH-002"
suspicious_ip = ""
suspicious_domain = "quickbooks.finance"
quarantine_hidden_risks = {"attachments": "missed_attachment_scan"}

