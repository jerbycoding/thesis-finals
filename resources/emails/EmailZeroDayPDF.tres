[gd_resource type="Resource" script_class="EmailResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/EmailResource.gd" id="1_email"]

[resource]
script = ExtResource("1_email")
email_id = "EMAIL-ZD-001"
sender = "Group Finance | Internal Audit Liaison"
subject = "URGENT: Board Resolution — Q1 Financial Audit Package (Confidential)"
body = "{victim},

The external auditors require the full Q1 reconciliation package before close of business today. CFO has approved distribution to audit-qualified staff only.

Please find the consolidated report attached (PDF). Due to document sensitivity, you will be prompted to enable extended content rendering to view the encrypted sections.

Do not forward. Do not print. Destroy after review.

Group Finance | Internal Audit Liaison"
attachments = ["Audit_Report_Q1_Final.pdf"]
headers = {"status": {"spf": "PASS", "dkim": "PASS", "dmarc": "PASS"}}
is_malicious = true
is_urgent = true
threat_category = 2
clues = ["bad_attachment"]
related_ticket = "ZERODAY-001"
suspicious_ip = "{ip}"
suspicious_domain = "{malicious_url}"
quarantine_hidden_risks = {"attachments": "missed_process_injection_before_isolate"}
