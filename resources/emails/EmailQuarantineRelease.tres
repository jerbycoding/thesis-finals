[gd_resource type="Resource" script_class="EmailResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/EmailResource.gd" id="1_email"]

[resource]
script = ExtResource("1_email")
email_id = "EMAIL-ZD-005"
sender = "Security Ops"
subject = "Quarantined Messages Release Notification"
body = "Hello {victim}, our security filters have held 3 unread messages in quarantine. To review and release these legitimate communications, authenticate via the secure mail portal: {malicious_url}."
attachments = []
headers = {"status": {"spf": "FAIL", "dkim": "FAIL", "dmarc": "PASS"}}
is_malicious = true
is_urgent = true
threat_category = 2
clues = ["suspicious_link", "suspicious_domain"]
related_ticket = "ZERODAY-005"
suspicious_ip = "{ip}"
suspicious_domain = "{malicious_url}"
quarantine_hidden_risks = {"links": "server_root_compromise"}
