[gd_resource type="Resource" script_class="EmailResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/EmailResource.gd" id="1_email"]

[resource]
script = ExtResource("1_email")
email_id = "EMAIL-WHALING-CEO"
sender = "legal-dept@doj-goverment-official.com"
subject = "URGENT: MANDATORY SUBPOENA FOR ACCOUNT DISCOVERY"
body = "To the Chief Executive Officer,

In accordance with federal regulation 12-B, you are required to submit your corporate credentials for a discovery audit regarding recent infrastructure instability. 

Failure to comply by 17:00 UTC will result in legal action. Submit credentials at the link below:

[http://doj-goverment-official.com/legal/subpoena-upload]

Do not discuss this request with internal SOC staff."
attachments = []
headers = {"status": {"dkim": "FAIL", "dmarc": "FAIL", "spf": "FAIL"}}
is_malicious = true
is_urgent = true
clues = ["suspicious_link", "suspicious_domain", "spoofed_sender"]
related_ticket = "WHALING-001"
suspicious_domain = "doj-goverment-official.com"
