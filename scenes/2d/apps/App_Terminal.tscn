[node name="VBoxContainer" type="VBoxContainer" parent="ColorRect"]
layout_mode = 0
anchor_right = 1.0
anchor_bottom = 1.0

[node name="HeaderLabel" type="Label" parent="ColorRect/VBoxContainer"]
