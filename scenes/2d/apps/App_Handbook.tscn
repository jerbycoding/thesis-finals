[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/2d/apps/App_Handbook.gd" id="1_handbook"]
[ext_resource type="Theme" path="res://assets/themes/EnterpriseTheme.tres" id="2_theme"]

[node name="AppHandbook" type="Control"]
custom_minimum_size = Vector2(900, 650)
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_handbook")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(1, 1, 1, 1)

[node name="MainLayout" type="HSplitContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
split_offset = 240

[node name="Sidebar" type="PanelContainer" parent="MainLayout"]
layout_mode = 2

[node name="Margin" type="MarginContainer" parent="MainLayout/Sidebar"]
layout_mode = 2
theme_override_constants/margin_left = 15
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 15

[node name="VBox" type="VBoxContainer" parent="MainLayout/Sidebar/Margin"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="SectionLabel" type="Label" parent="MainLayout/Sidebar/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 0.4, 0.4, 1)
theme_override_font_sizes/font_size = 10
text = "DOCUMENTATION"

[node name="NavButtons" type="VBoxContainer" parent="MainLayout/Sidebar/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 5

[node name="Btn_Terminal" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  🐚 Terminal Guide"
alignment = 0
flat = true

[node name="Btn_Network" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  🕸️ Network Map"
alignment = 0
flat = true

[node name="Btn_SIEM" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  📊 SIEM Forensics"
alignment = 0
flat = true

[node name="Btn_Email" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  ✉ Email Analysis"
alignment = 0
flat = true

[node name="HSeparator" type="HSeparator" parent="MainLayout/Sidebar/Margin/VBox"]
layout_mode = 2

[node name="Btn_Procedures" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  📜 SOP Procedures"
alignment = 0
flat = true

[node name="Btn_Incidents" type="Button" parent="MainLayout/Sidebar/Margin/VBox/NavButtons"]
layout_mode = 2
text = "  🎫 Incident Catalog"
alignment = 0
flat = true

[node name="ReaderPane" type="VBoxContainer" parent="MainLayout"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 0

[node name="DocHeader" type="PanelContainer" parent="MainLayout/ReaderPane"]
custom_minimum_size = Vector2(0, 45)
layout_mode = 2
theme_type_variation = &"HeaderPanel"

[node name="TitleLabel" type="Label" parent="MainLayout/ReaderPane/DocHeader"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"TechnicalHeader"
text = ":: SOC_HANDBOOK v4.4 ::"
vertical_alignment = 1

[node name="ContentMargin" type="MarginContainer" parent="MainLayout/ReaderPane"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/margin_left = 40
theme_override_constants/margin_top = 30
theme_override_constants/margin_right = 40
theme_override_constants/margin_bottom = 30

[node name="Reader" type="RichTextLabel" parent="MainLayout/ReaderPane/ContentMargin"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/line_separation = 6
theme_override_font_sizes/normal_font_size = 14
bbcode_enabled = true
text = "Select a topic..."
