[node name="RepairBtn" type="Button" parent="Panel/Margin/VBox/HBox"]
layout_mode = 2
size_flags_horizontal = 3
text = "INITIATE REPAIR"

[connection signal="pressed" from="Panel/Margin/VBox/HBox/VerifyBtn" to="." method="_on_verify_pressed"]
