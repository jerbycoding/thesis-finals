[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/DiagnosticUI.gd" id="1_diag"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_box"]
bg_color = Color(0.05, 0.05, 0.1, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0, 1, 1, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[node name="DiagnosticUI" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_diag")

[node name="Dimmer" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.4)

[node name="Panel" type="PanelContainer" parent="."]
custom_minimum_size = Vector2(400, 350)
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -175.0
offset_right = 200.0
offset_bottom = 175.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_box")

[node name="Margin" type="MarginContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBox" type="VBoxContainer" parent="Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 15

[node name="Title" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 1, 1, 1)
theme_override_font_sizes/font_size = 20
text = "HARDWARE DIAGNOSTIC"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="Panel/Margin/VBox"]
layout_mode = 2

[node name="Stats" type="VBoxContainer" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TempLabel" type="Label" parent="Panel/Margin/VBox/Stats"]
unique_name_in_owner = true
layout_mode = 2
text = "CORE TEMP: 45.0°C"

[node name="LossLabel" type="Label" parent="Panel/Margin/VBox/Stats"]
unique_name_in_owner = true
layout_mode = 2
text = "PACKET LOSS: 0.0%"

[node name="VoltLabel" type="Label" parent="Panel/Margin/VBox/Stats"]
unique_name_in_owner = true
layout_mode = 2
text = "BUS VOLTAGE: 12.0V"

[node name="StatusLabel" type="Label" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "ANALYSIS: SYSTEM NOMINAL"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Panel/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="HBox" type="HBoxContainer" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="VerifyBtn" type="Button" parent="Panel/Margin/VBox/HBox"]
layout_mode = 2
size_flags_horizontal = 3
