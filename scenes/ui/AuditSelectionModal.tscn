[sub_resource type="GDScript" id="4"]
script/source = "extends PanelContainer

signal action_selected(type: String)

@onready var status_label = %StatusLabel
@onready var desc_label = %DescLabel
@onready var action_button = %ActionButton
@onready var cancel_button = %CancelButton

func setup(is_critical: bool):
	Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
	if is_critical:
		status_label.text = \"STATUS: ANOMALY_DETECTED\"
		status_label.add_theme_color_override(\"font_color\", Color(0.8, 0.2, 0.2))
		desc_label.text = \"System integrity check required to clear pending security flags.\"
		action_button.text = \"FIX THE ROUTER\"
	else:
		status_label.text = \"STATUS: NOMINAL\"
		status_label.add_theme_color_override(\"font_color\", Color(0.2, 0.6, 0.2))
		desc_label.text = \"All sub-systems are within established parameters. Manual audit is optional.\"
		action_button.text = \"VERIFY & CLOSE\"

func _ready():
	action_button.pressed.connect(func(): 
		Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
		action_selected.emit(\"action\")
		queue_free()
	)
	
	cancel_button.pressed.connect(func(): 
		Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
		action_selected.emit(\"cancel\")
		queue_free()
	)
"

